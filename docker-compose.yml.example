services:
  openclaw:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: openclaw-gateway
    restart: unless-stopped
    
    ports:
      - "${OPENCLAW_EXPOSE_IP:-127.0.0.1}:${OPENCLAW_GATEWAY_PORT:-18789}:18789"
    
    volumes:
      - ./openclaw-data:/home/openclaw/.openclaw
      # - ./config:/home/openclaw/.openclaw/config:ro 
    
    environment:
      - NODE_ENV=${NODE_ENV:-production}
      - NODE_OPTIONS=${NODE_OPTIONS:---max-old-space-size=2048}
      - BRAVE_API_KEY=xxx
      - NOTION_API_KEY=xxx
      - OPENCLAW_GATEWAY_TOKEN=xxx

      - OPENCLAW_HOST=${OPENCLAW_HOST:-0.0.0.0}
      - OPENCLAW_GATEWAY_PORT=${OPENCLAW_GATEWAY_PORT:-18789}
      - OPENCLAW_BIND=${OPENCLAW_BIND:-lan}
      
      - OPENCLAW_SANDBOX_MODE=${OPENCLAW_SANDBOX_MODE:-non-main}
      - OPENCLAW_LOG_LEVEL=${OPENCLAW_LOG_LEVEL:-info}

      - OPENCLAW_HOME=${OPENCLAW_HOME:-/home/openclaw/.openclaw}
      - PNPM_HOME=${PNPM_HOME:-/home/openclaw/.local/share/pnpm}
    
    networks:
      - openclaw-network
    
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: '2'
          pids: 100
        reservations:
          memory: 512M
          cpus: '0.5'
    
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    read_only: false
    
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  linkedin-research-worker:
    build:
      context: ./openclaw-data/.openclaw/linkedin-research-worker
      dockerfile: Dockerfile
    container_name: linkedin-research-worker
    restart: unless-stopped

    environment:
      - NODE_ENV=production
      - PORT=3000
      - HOST=0.0.0.0
      - HEADLESS=true
      - NAV_TIMEOUT_MS=30000
      - LINKEDIN_STORAGE_STATE_PATH=/app/state/linkedin-storage-state.json
      - DEBUG_ARTIFACTS_DIR=/app/debug
      # - WORKER_API_KEY=pon_aqui_un_token

    volumes:
      - ./linkedin-research-worker-state:/app/state
      - ./linkedin-research-worker-debug:/app/debug

    networks:
      - openclaw-network

    shm_size: "1gb"
    init: true

    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

networks:
  openclaw-network:
    driver: bridge