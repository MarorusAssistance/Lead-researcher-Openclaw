{
  "name": "linkedin-research-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": ">=22.16.0"
  },
  "workspaces": [
    "packages/*",
    "plugins/*",
    "workers/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
