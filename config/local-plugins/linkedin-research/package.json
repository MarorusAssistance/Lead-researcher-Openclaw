{
  "name": "linkedin-research",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw plugin that proxies LinkedIn research requests to an external worker",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "openclaw": "^2026.3.13"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}